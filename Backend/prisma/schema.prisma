model ChatMessage {
  id                  String                @id @default(cuid())
  chatContextType     ChatContextType       @default(GAME)
  contextId           String
  gameId              String?
  senderId            String?
  content             String?
  contentSearchable   String?
  mediaUrls           String[]
  thumbnailUrls       String[]
  mentionIds          String[]
  state               MessageState          @default(SENT)
  chatType            ChatType              @default(PUBLIC)
  messageType         MessageType           @default(TEXT)
  audioDurationMs     Int?
  videoDurationMs     Int?
  videoWidth          Int?
  videoHeight         Int?
  waveformData        Float[]               @default([])
  /// Set iff messageType = DOCUMENT; display name from upload.
  documentFileName    String?
  documentMimeType    String?
  documentSize        Int?
  /// Set iff messageType = STICKER; catalog identity (mediaUrls stay empty).
  stickerId           String?
  /// Denormalized emoji for list preview / old clients without catalog join.
  stickerEmoji        String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  editedAt            DateTime?
  deletedAt           DateTime?
  clientMutationId    String?
  /// Sync log seq last written onto this ChatMessage row (create, edit, delete, delivery state). Side tables (reactions, etc.) do not bump this; idempotent create replays use this as syncSeq, not head.
  serverSyncSeq       Int?
  replyToId           String?
  /// Instagram-style story reply context: { sourceType, sourceId, ownerUserId, thumbnailUrl?, mediaUrl?, mediaType? }
  storyReply          Json?
  /// Snapshot of first eligible URL preview at send (LinkPreviewResult JSON); clients may still refresh.
  linkPreview         Json?
  linkPreviewUrl      String?
  /// Sender-controlled per-message suppression; URL text remains untouched.
  linkPreviewDisabled Boolean               @default(false)
  /// Original message this row forwards (shared CDN URLs; SetNull if original deleted).
  forwardedFromMessageId String?
  /// Attribution snapshot: { title, chatContextType, contextId, isChannel?, messageId }
  forwardedFrom          Json?
  replyTo             ChatMessage?          @relation("MessageReply", fields: [replyToId], references: [id])
  replies             ChatMessage[]         @relation("MessageReply")
  forwardedFromMessage ChatMessage?         @relation("MessageForward", fields: [forwardedFromMessageId], references: [id], onDelete: SetNull)
  forwards             ChatMessage[]        @relation("MessageForward")
  sender              User?                 @relation(fields: [senderId], references: [id], onDelete: Cascade)
  sticker             Sticker?              @relation(fields: [stickerId], references: [id], onDelete: Restrict)
  reactions           MessageReaction[]
  readReceipts        MessageReadReceipt[]
  reports             MessageReport[]
  translations        MessageTranslation[]
  audioTranscription  MessageTranscription?
  poll                Poll?
  pollId              String?               @unique
  pinnedIn            PinnedMessage[]

  @@unique([senderId, clientMutationId])
  @@index([chatContextType, contextId])
  @@index([chatContextType, contextId, deletedAt], map: "idx_ChatMessage_unread_count")
  @@index([chatContextType, contextId, serverSyncSeq])
  @@index([gameId])
  @@index([gameId, createdAt(sort: Desc)], map: "idx_ChatMessage_gameId_createdAt")
  @@index([senderId])
  @@index([createdAt])
  @@index([state])
  @@index([replyToId])
  @@index([forwardedFromMessageId])
  @@index([chatType])
  @@index([contextId])
  @@index([deletedAt])
  @@index([stickerId])
}

