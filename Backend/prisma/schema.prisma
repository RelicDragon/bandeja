}

model StickerPack {
  id             String    @id @default(cuid())
  slug           String    @unique
  title          String
  sport          Sport?
  locale         String?
  /// Official catalog packs are true; personal “My stickers” packs are false.
  isOfficial     Boolean   @default(true)
  /// Owner of a personal pack. Null for official packs. At most one personal pack per user.
  ownerUserId    String?
  isActive       Boolean   @default(true)
  coverStickerId String?   @unique
  sortOrder      Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
