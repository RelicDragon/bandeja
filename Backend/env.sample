# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
# HTTP port for the Express API
PORT=3000
# development | production | test
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Individual fields (used by app config helpers, scripts)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=padelpulse_dev
DB_USER=postgres
DB_PASSWORD=postgres
DB_SCHEMA=padelpulse

# Prisma: full connection URL (see prisma/schema.prisma datasource)
DB_URL=postgresql://postgres:postgres@localhost:5432/padelpulse_dev?schema=padelpulse

# -----------------------------------------------------------------------------
# Auth (JWT)
# -----------------------------------------------------------------------------
# Secret for signing access tokens; must be strong in production
JWT_SECRET=your-secret-key-change-in-production
# Token lifetime (e.g. 90d, 7d)
JWT_EXPIRES_IN=90d

# -----------------------------------------------------------------------------
# Telegram
# -----------------------------------------------------------------------------
# Bot token from @BotFather (grammy bot, OTP, notifications)
TELEGRAM_BOT_TOKEN=

# -----------------------------------------------------------------------------
# URLs (not read by src/config/env.ts; kept for local/docs compatibility)
# -----------------------------------------------------------------------------
IMAGE_BASE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Frontend / CORS
# -----------------------------------------------------------------------------
# Origin allowed by CORS and used in links (invites, deep links, etc.)
FRONTEND_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Push — Apple (APNs) — iOS
# -----------------------------------------------------------------------------
# Apple Developer: Keys → APNs Auth Key
APNS_KEY_ID=
APNS_TEAM_ID=
# iOS app bundle id (defaults in code: com.funified.bandeja)
APNS_BUNDLE_ID=com.funified.bandeja
# Path to .p8 key file on the server
APNS_KEY_PATH=
# true = production APNs; false = sandbox
APNS_PRODUCTION=false

# -----------------------------------------------------------------------------
# Push — Firebase (FCM) — Android
# -----------------------------------------------------------------------------
# Firebase Console → Project settings → Service accounts → Generate new key
FCM_PROJECT_ID=bandeja-padel
FCM_PRIVATE_KEY=
FCM_CLIENT_EMAIL=

# -----------------------------------------------------------------------------
# AWS S3 & CDN (uploads, media)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# e.g. eu-central-1
AWS_REGION=eu-central-1
AWS_S3_BUCKET=bandeja-padel-eu
# Hostname for public media URLs (CloudFront or bucket domain)
AWS_CLOUDFRONT_DOMAIN=d1afylun4w6qxe.cloudfront.net

# -----------------------------------------------------------------------------
# AI (translations, chat features, Whisper when using OpenAI)
# -----------------------------------------------------------------------------
# openai | deepseek
AI_PROVIDER=openai
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# -----------------------------------------------------------------------------
# OAuth — Apple
# -----------------------------------------------------------------------------
# Services ID / bundle client id for Sign in with Apple (defaults in code: com.funified.bandeja)
APPLE_CLIENT_ID=com.funified.bandeja

# -----------------------------------------------------------------------------
# OAuth — Google
# -----------------------------------------------------------------------------
# Google Cloud Console → APIs & Services → Credentials (Web, iOS, Android clients)
GOOGLE_WEB_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=

# -----------------------------------------------------------------------------
# Puppeteer (optional)
# -----------------------------------------------------------------------------
# System Chrome/Chromium path if bundled Chrome fails (e.g. /usr/bin/chromium-browser)
PUPPETEER_EXECUTABLE_PATH=

# -----------------------------------------------------------------------------
# City groups & geolocation
# -----------------------------------------------------------------------------
# User id whose account posts the pinned city-group welcome message (backfill / onboarding)
CITY_GROUP_WELCOME_SENDER_ID=
# City UUID used when IP-based city detection cannot resolve a city
FALLBACK_CITY_ID=
# true = city groups: join system message on auto-add; omit leave system messages
CITY_GROUP_REFINED_SYSTEM_MESSAGES=

# -----------------------------------------------------------------------------
# Chat sync (ops)
# -----------------------------------------------------------------------------
# true = weekly log: ChatSyncEvent row count + span, ConversationSyncState context count (no deletion)
CHAT_SYNC_STATS_LOG=
# Delete ChatSyncEvent rows older than N days (weekly cron). 0 = disabled.
# Clients with lastAppliedSeq before the oldest retained row get cursorStale + thread reload.
CHAT_SYNC_EVENT_RETENTION_DAYS=0
# true = one JSON line per /api/chat/sync/* error (stderr; ship to log drain / APM)
CHAT_SYNC_HTTP_ERROR_LOG=
# Delete ChatMutationIdempotency rows older than N days (weekly cron with chat sync job). 0 = disabled.
CHAT_MUTATION_IDEM_RETENTION_DAYS=0

# -----------------------------------------------------------------------------
# Other (not referenced in src/config/env.ts)
# -----------------------------------------------------------------------------
ABSTRACT_API_KEY=
