{
  "name": "padelpulse-backend",
  "version": "1.0.0",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11"
  },
  "description": "Backend for Bandeja - Padel game scheduling app",
  "main": "dist/server.js",
  "scripts": {
    "prebuild": "npm run build:contract && npm run build:unread-contract && npm run build:shared",
    "build:contract": "npm run build --prefix ../packages/chat-contract",
    "build:unread-contract": "npm run build --prefix ../packages/unread-contract",
    "build:shared": "npm run build --prefix ../Frontend/shared",
    "dev": "nodemon src/server.ts",
    "worker": "ts-node -r dotenv/config src/worker.ts",
    "dev:setup": "./dev-setup.sh",
    "build": "tsc",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "lint": "eslint src --ext .ts",
    "migrate-to-s3": "ts-node scripts/migrate-to-s3.ts",
    "load-playtomic-jsons": "ts-node scripts/load-playtomic-jsons.ts",
    "export-geo-translations": "ts-node scripts/export-geo-translations.ts",
    "detect-same-cities": "ts-node scripts/detect-same-cities.ts",
    "backfill:last-message-previews": "ts-node scripts/backfillLastMessagePreviews.ts",
    "backfill:content-searchable": "ts-node scripts/backfillContentSearchable.ts",
    "backfill:training-trainer-id": "ts-node scripts/backfillTrainingTrainerId.ts",
    "backfill:welcome-screen-passed": "ts-node scripts/backfillWelcomeScreenPassed.ts",
    "backfill:bug-finished-at": "ts-node scripts/backfillBugFinishedAt.ts",
    "backfill:bug-testing-started-at": "ts-node scripts/backfillBugTestingStartedAt.ts",
    "backfill:league-delta-scores": "ts-node scripts/backfillLeagueDeltaScores.ts",
    "backfill:city-groups": "ts-node scripts/backfillCityGroups.ts",
    "backfill:city-group-welcome-messages": "ts-node scripts/backfillCityGroupWelcomeMessages.ts",
    "backfill:user-name-is-set": "ts-node scripts/backfillUserNameIsSet.ts",
    "backfill:city-is-set": "ts-node scripts/backfillCityIsSet.ts",
    "backfill:padel-questionnaire-from-welcome": "ts-node scripts/backfillPadelQuestionnaireFromWelcome.ts",
    "backfill:sport-questionnaire-markers": "ts-node scripts/backfillSportQuestionnaireMarkers.ts",
    "backfill:padel-questionnaire-markers": "ts-node scripts/backfillSportQuestionnaireMarkers.ts",
    "backfill:game-booking-status": "ts-node scripts/backfillGameBookingStatus.ts",
    "reconcile:sport-profile-level-from-events": "ts-node scripts/reconcileSportProfileLevelFromEvents.ts",
    "reconcile:sport-profile-game-stats": "ts-node scripts/reconcileSportProfileGameStats.ts",
    "restore:reliability-from-latest-outcome": "ts-node scripts/restoreReliabilityFromLatestOutcome.ts",
    "backfill:last-rating-activity-at": "ts-node scripts/backfillLastRatingActivityAt.ts",
    "backfill:play-streak": "ts-node scripts/backfillPlayStreak.ts",
    "audit:court-club-sports": "ts-node scripts/audit-court-club-sports.ts",
    "backfill:court-club-sports": "ts-node scripts/backfill-court-club-sports.ts",
    "seed:padeloo-avantura": "ts-node -r dotenv/config scripts/seed-padeloo-avantura.ts",
    "generate:sticker-assets": "ts-node --transpile-only scripts/generate-sticker-assets.ts",
    "seed:sticker-packs": "ts-node -r dotenv/config scripts/seed-sticker-packs.ts",
    "test:chat-message-type": "ts-node --transpile-only src/services/chat/resolveOutgoingChatMessageType.test.ts",
    "test:sticker-assets": "ts-node --transpile-only src/services/stickers/stickerAsset.service.test.ts",
    "test:sticker-prefs": "ts-node --transpile-only src/services/stickers/stickerPrefsNormalize.test.ts",
    "test:sticker-pack-sort": "ts-node --transpile-only src/services/stickers/stickerPackSort.test.ts",
    "test:court-club-sports-reconcile": "ts-node scripts/lib/courtClubSportsReconcile.test.ts",
    "sunset:user-rating-columns": "ts-node scripts/sunsetUserRatingColumns.ts",
    "backfill:non-rating-game-level-events": "ts-node scripts/backfillNonRatingGameLevelEvents.ts",
    "fix:booktime-game-times": "ts-node scripts/fix-booktime-game-times.ts",
    "backfill:weather-day-archives": "ts-node scripts/backfillWeatherDayArchives.ts",
    "migrateBugsToGroups": "ts-node scripts/migrateBugsToGroups.ts",
    "test:currency": "ts-node scripts/test-currency-service.ts",
    "example:currency": "ts-node examples/currency-integration-example.ts",
    "qa:allow-multi-teams": "ts-node scripts/qa-allowUserInMultipleTeams.ts",
    "qa:league-round-gen": "ts-node scripts/qa-leagueRoundGeneration.ts",
    "qa:americano-random-round-gen": "node -r dotenv/config node_modules/ts-node/dist/bin.js scripts/qa-americanoRandomRoundGeneration.ts",
    "test:available-games": "ts-node --transpile-only src/services/game/availableGamesBounds.test.ts && ts-node --transpile-only src/services/game/availableGamesCard.projection.test.ts && ts-node --transpile-only src/services/game/availableGamesStructuralWhere.test.ts && ts-node --transpile-only src/services/game/availableGamesEnrichment.test.ts && ts-node --transpile-only src/services/game/availableGamesProtocol.test.ts && ts-node --transpile-only src/services/game/availableGamesEnrich.defer.test.ts && ts-node --transpile-only src/services/game/availableGamesDayIndex.cap.test.ts && ts-node --transpile-only src/services/game/availableGamesQuery.calendarDate.test.ts",
    "test:automated": "node -r dotenv/config node_modules/ts-node/dist/bin.js scripts/tests/run-all.ts",
    "test:bracket-structure": "ts-node scripts/generate-bracket-fixtures.ts && ts-node src/services/league/bracketStructure.test.ts && ts-node src/services/league/bracketSlotEdit.util.test.ts && ts-node src/services/league/crossGroupBracketSeeding.test.ts && ts-node src/services/league/crossGroupBracketScope.test.ts && ts-node src/services/league/leagueBracketDeepLink.util.test.ts && ts-node src/services/league/bracketScheduleListSort.util.test.ts",
    "test:game-results-artifacts": "ts-node src/services/gameResultsArtifact/gameResultsArtifact.readiness.test.ts && ts-node src/services/gameResultsArtifact/gameResultsArtifact.enqueuePolicy.test.ts && ts-node src/services/gameResultsArtifact/gameResultsArtifact.photoLimit.test.ts && ts-node -r dotenv/config src/services/gameResultsArtifact/gameResultsArtifact.photoApplyClaim.test.ts && ts-node src/services/gameResultsArtifact/gameResultsArtifact.dto.test.ts && ts-node src/services/gameResultsArtifact/gameResultsArtifactStory.eligibility.test.ts && ts-node src/services/gameResultsArtifact/gameResultsArtifact.avatarInput.test.ts && ts-node src/services/gameResultsArtifact/gameResultsArtifact.photoStyles.test.ts && ts-node src/services/gameResultsArtifact/gameResultsArtifact.photoContext.test.ts && ts-node src/services/replicate/models/flux2.model.test.ts && ts-node src/services/replicate/models/nanoBanana2.model.test.ts && ts-node src/services/replicate/models/gptImage2.model.test.ts && ts-node src/services/replicate/models/replicateImageModel.selector.test.ts && ts-node -r dotenv/config src/services/gameResultsArtifact/gameResultsArtifact.service.integration.test.ts && ts-node -r dotenv/config scripts/tests/game-results-artifacts.ts"
  },
  "keywords": [
    "padel",
    "sports",
    "scheduling"
  ],
  "author": "",
  "license": "ISC",
  "overrides": {
    "jsonwebtoken": "^9.0.3",
    "node-forge": "^1.4.0",
    "uuid": "^11.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@bandeja/chat-contract": "file:../packages/chat-contract",
    "@bandeja/shared": "file:../Frontend/shared",
    "@bandeja/unread-contract": "file:../packages/unread-contract",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sindresorhus/transliterate": "^2.3.1",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/multer": "^2.0.0",
    "apn": "^2.2.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.4.5",
    "edmonds-blossom": "^1.0.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "firebase-admin": "^13.10.0",
    "franc": "^6.2.0",
    "google-auth-library": "^10.5.0",
    "grammy": "^1.43.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^3.2.1",
    "morgan": "^1.11.0",
    "multer": "^2.1.1",
    "munkres": "^2.0.4",
    "music-metadata": "^11.12.3",
    "node-cron": "^4.2.1",
    "openai": "^6.42.0",
    "pg": "^8.21.0",
    "puppeteer": "^25.0.4",
    "redis": "^6.0.0",
    "replicate": "^1.4.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "tinyld": "^1.3.4",
    "unique-names-generator": "^4.7.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@clack/prompts": "^1.6.0",
    "@eslint/js": "^9.38.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/edmonds-blossom": "^1.0.4",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^24.9.2",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^9.11.0",
    "execa": "^8.0.1",
    "globals": "^16.4.0",
    "listr2": "^10.2.1",
    "nodemon": "^3.1.14",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.2",
    "typescript": "6.0.3"
  }
}
