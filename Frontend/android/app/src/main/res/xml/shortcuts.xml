<?xml version="1.0" encoding="utf-8"?>
<!--
  Feature layer (#279): static OPEN_APP_FEATURE shortcuts → catalog deep-link URLs.
  Game-entity shortcuts are dynamic only (DynamicGameShortcuts / dyn_game_*) — not listed here.
  Launcher shows at most 5 static shortcuts (file order). Extra entries still feed App Actions.
  URLs — keep equal to Frontend/src/deepLinks/catalog.mirror.json (#278).
  Registry — Frontend/src/deepLinks/assistantRegistry.ts.
-->
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">

    <capability android:name="actions.intent.OPEN_APP_FEATURE">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.funified.bandeja"
            android:targetClass="com.funified.bandeja.MainActivity">
            <url-template android:value="https://bandeja.me/" />
        </intent>
        <shortcut-fulfillment>
            <parameter android:name="feature" />
        </shortcut-fulfillment>
    </capability>

    <shortcut
        android:shortcutId="find_games"
        android:enabled="true"
        android:icon="@mipmap/ic_launcher"
        android:shortcutShortLabel="@string/shortcut_find_games_short"
        android:shortcutLongLabel="@string/shortcut_find_games_long">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.funified.bandeja"
            android:targetClass="com.funified.bandeja.MainActivity"
            android:data="https://bandeja.me/find?view=calendar&amp;dayOffset=0" />
        <capability-binding android:key="actions.intent.OPEN_APP_FEATURE">
            <parameter-binding
                android:key="feature"
                android:value="@array/shortcut_find_games_synonyms" />
        </capability-binding>
    </shortcut>

    <shortcut
