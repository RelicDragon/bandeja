# E2E targets local dev servers only (localhost). Non-local URLs are rejected.
# E2E_BASE_URL=http://localhost:3001
# E2E_API_URL=http://localhost:3000/api
#
# Backend must use padelpulse_dev (DB_NAME=padelpulse_dev) with NODE_ENV=development.
# E2E aborts if /health reports a different database or production runtime.
