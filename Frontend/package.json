{
  "name": "padelpulse-frontend",
  "version": "1.0.0",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "npm run build:contracts",
    "build:contracts": "npm run build:contract && npm run build:unread-contract",
    "build:contract": "npm run build --prefix ../packages/chat-contract",
    "build:unread-contract": "npm run build --prefix ../packages/unread-contract",
    "build": "tsc && vite build",
    "postbuild": "node scripts/force-sw-update.js",
    "preview": "vite preview",
    "test:deep-link-catalog": "vitest run src/deepLinks/catalog.parity.test.ts src/deepLinks/catalog.path.test.ts src/deepLinks/assistantRegistry.parity.test.ts",
    "sync:deep-link-catalog": "node --experimental-strip-types scripts/sync-deep-link-catalog.ts",
    "test:next-game": "vitest run src/utils/pickNextGame.test.ts src/utils/resolveNextGamePath.test.ts",
    "verify:next-game": "bash scripts/verify-next-game-parity.sh",
    "test:ios-shared-packages": "bash ios/scripts/run-ios-shared-package-tests.sh",
    "test:live-scoring": "vitest run src/utils/liveScoring/core.test.ts src/utils/liveScoring/badmintonServe.test.ts src/utils/liveScoring/squashServe.test.ts src/utils/liveScoring/pickleballServe.test.ts src/utils/liveScoring/serveGuideGolden.test.ts src/utils/liveScoring/scoringGolden.test.ts src/liveScoring/registry.test.ts src/liveScoring/rallyScoreMeta.test.ts src/sport/sportRegistry.test.ts src/sport/badmintonFlow.verify.test.ts src/sport/createTemplates.parity.test.ts src/utils/profileSports.test.ts src/utils/findSportFilter.test.ts src/components/liveScoring/rally/pickleballCourt.test.ts src/components/liveScoring/rally/squashCourtLayout.test.ts",
    "test:game-results-share": "node scripts/verify-game-results-share-export.mjs",
    "test:game-invite": "vitest run src/utils/gameInviteParticipant.test.ts",
    "test:invites": "vitest run src/utils/gameInviteParticipant.test.ts src/api/invites.myTabCache.test.ts src/queries/games/removeInviteFromMyGamesCache.test.ts",
    "test:group-channel": "vitest run src/utils/groupChannelParticipation.test.ts",
    "test:queries": "vitest run src/queries/useUserStatsQuery.test.ts src/queries/queryInvalidationBridge.test.ts src/queries/games/*.test.ts src/features/playerProfile/loadPlayerProfileData.test.ts src/widgets/cachedNextGameDto.test.ts src/services/widgetNextGamesSync.test.ts",
    "test:find": "vitest run src/utils/findFilter.test.ts src/utils/findDayIndexCounts.test.ts src/utils/findClientHeuristic.test.ts src/utils/findStructuralApiParams.test.ts src/utils/attachAvailableGamesEnrichment.test.ts src/utils/gameFiltersStorage.test.ts src/utils/findPanelFiltersApplied.test.ts src/utils/pruneFindFilterClubIds.test.ts src/hooks/useAvailableGames.loading.test.ts src/hooks/useGameFilters.persist.test.tsx src/queries/queryInvalidationBridge.test.ts src/queries/games/useAvailableGamesQuery.test.ts src/queries/games/availableGamesPage.test.ts src/queries/games/mergeFindCardGame.test.ts src/queries/games/patchGameInGamesCaches.test.ts",
    "test:chat-inbox-feed": "vitest run src/utils/chatListCityGroup.test.ts src/utils/chatListDexMerge.test.ts src/services/chat/inbox/chatInboxFeedPrepare.test.ts",
    "test:chat-drafts": "vitest run src/components/chat/messageInputDraftSwitch.test.ts src/components/chat/useMessageInputDraftSync.test.tsx src/components/chat/draftDeleteFlow.test.ts",
    "test:unread": "vitest run src/hooks/unreadAuthBootstrapRefresh.test.ts src/services/chat/unreadCoordinator.test.ts src/services/chat/unreadProjection.test.ts src/store/unreadStore.test.ts src/api/chatUnreadCache.test.ts src/services/chat/unreadSnapshot.test.ts src/services/push/syncAppBadgeAfterPushReply.test.ts src/services/chat/__tests__/chatSyncService.test.ts",
    "test:chat-open": "vitest run src/services/chat/__tests__/mergeReadReceipts.test.ts src/services/chat/__tests__/mergeOpenSnapshot.test.ts src/services/chat/__tests__/threadSession.test.ts src/services/chat/__tests__/gameChatOpenPerformance.test.ts src/services/chat/__tests__/threadOpen.test.ts src/services/chat/__tests__/threadOpenPlan.test.ts src/services/chat/__tests__/shouldPinOnOpen.test.ts src/services/chat/optimisticReconcile.test.ts src/services/chat/__tests__/chatLocalApplyThreadEvent.test.ts src/services/chat/__tests__/chatLocalApplySocketInbound.test.ts src/services/chat/__tests__/chatLocalApplyPull.test.ts src/services/chat/__tests__/chatLocalApplyWrite.test.ts src/services/chat/__tests__/chatBulkAllRead.test.ts src/services/chat/chatThreadController/__tests__/chatThreadController.test.ts src/services/chat/chatThreadController/__tests__/chatThreadControllerChatTypes.test.ts src/services/chat/chatThreadController/__tests__/processChatRoomBatch.test.ts",
    "test:chat-outbox": "vitest run src/services/chat/chatSendCoordinator.test.ts src/services/chat/chatOutboxEnqueue.test.ts src/services/chat/chatOutboxRetry.test.ts src/services/chat/chatOutboxSendResume.test.ts src/services/chat/messageSendState.test.ts src/services/chat/chatSendSocketAck.test.ts src/services/chat/chatSendMessageCreate.test.ts src/services/chat/chatHttpRetry.test.ts src/services/chat/chatVideoTranscode.test.ts src/services/chat/chatVideoTranscodeWorkerClient.test.ts src/services/chat/chatVideoUploadRetry.test.ts src/services/chat/chatVideoPoster.test.ts src/services/chat/chatVideoMetadata.test.ts src/services/chat/chatVideoAsyncTimeout.test.ts src/services/chat/chatVideoPrepare.test.ts src/services/chatMessageQueueStorage.video.test.ts && cd ../Backend && npx ts-node scripts/tests/chat-video-message-type.ts",
    "test:chat-stickers": "vitest run src/utils/saveAsSticker.test.ts src/utils/stickerTrayPacks.test.ts src/utils/stickerPrefsOrder.test.ts src/utils/stickerPreview.test.ts src/utils/replyPreviewContent.test.ts src/utils/buildReplyToRef.test.ts src/utils/gifProviderUrl.test.ts src/components/MessageItem/messageMediaUrl.test.ts src/components/chat/giphySearchItems.test.ts src/services/stickers/stickerCatalogCache.test.ts src/services/chat/chatMediaAssetCache.test.ts src/services/chat/chatOutboxGiphy.test.ts src/services/chat/chatOutboxImageCompress.test.ts src/services/chat/chatOutboxSticker.test.ts",
    "test:stories": "vitest run src/components/stories/create/utils/storyTransform.test.ts src/components/stories/create/utils/storyCanvasExport.test.ts src/components/stories/create/utils/layoutCanvasText.test.ts src/components/stories/create/utils/storyCanvasHitTest.test.ts src/components/stories/create/utils/storyExportDimensions.test.ts src/components/stories/create/photo/utils/storyRenderParity.test.ts src/components/stories/create/video/useStoryVideoPublish.test.ts src/components/stories/create/photo/hooks/useStoryPhotoPublish.test.ts src/components/stories/slides/MediaStorySlide.test.tsx",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "increment-sw": "node scripts/increment-sw-version.js",
    "test:e2e": "env -u FORCE_COLOR -u NO_COLOR playwright test",
    "test:e2e:guest": "env -u FORCE_COLOR -u NO_COLOR playwright test --project=guest",
    "test:e2e:auth": "env -u FORCE_COLOR -u NO_COLOR playwright test --project=authenticated",
    "test:e2e:two-user": "env -u FORCE_COLOR -u NO_COLOR playwright test --project=two-user",
    "test:e2e:ui": "env -u FORCE_COLOR -u NO_COLOR playwright test --ui",
    "test:e2e:headed": "env -u FORCE_COLOR -u NO_COLOR playwright test --headed",
    "test:e2e:report": "env -u FORCE_COLOR -u NO_COLOR playwright show-report"
  },
  "dependencies": {
    "@bandeja/chat-contract": "file:../packages/chat-contract",
    "@bandeja/unread-contract": "file:../packages/unread-contract",
