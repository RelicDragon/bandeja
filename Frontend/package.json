    "@emoji-mart/react": "^1.1.1",
    "@headlessui/react": "^2.2.9",
    "@lottiefiles/dotlottie-react": "^0.18.2",
    "@paralleldrive/cuid2": "^3.0.4",
    "@radix-ui/react-dialog": "^1.1.15",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
