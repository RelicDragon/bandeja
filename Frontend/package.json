    "react-leaflet": "^5.0.0",
    "react-leaflet-cluster": "^4.0.0",
    "react-mentions": "^4.4.10",
    "react-router-dom": "^7.17.0",
    "recharts": "^3.4.1",
    "socket.io-client": "^4.8.3",
